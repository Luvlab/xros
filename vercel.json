{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/xros", "destination": "/index.html" },
    { "source": "/xros/", "destination": "/index.html" },
    { "source": "/xros/advertiser", "destination": "/advertiser.html" },
    { "source": "/xros/(.*)", "destination": "/$1" }
  ]
}
