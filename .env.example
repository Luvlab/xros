# -----------------------------------------------------------------------------
# XR Search Engine — environment variables
# Copy this file to .env and fill in the values.
# -----------------------------------------------------------------------------

# Supabase project URL (Project Settings → API → Project URL)
VITE_SUPABASE_URL=

# Supabase anon/public key (Project Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=

# Optional: default AI provider config can be set by users in-app (BYOK); no server keys needed for Phase 1.
